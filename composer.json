{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "terloquent/id",
    "description": "🌏 Eloquent models for Indonesian administrative regions — no database required.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "eloquent",
        "indonesia",
        "administrative-divisions",
        "territory",
        "region",
        "sushi"
    ],
    "homepage": "https://github.com/dominosaurs/terloquent-id",
    "support": {
        "issues": "https://github.com/dominosaurs/terloquent-id/issues",
        "source": "https://github.com/dominosaurs/terloquent-id"
    },
    "authors": [
        {
            "name": "🍕",
            "email": "zainadam.id@gmail.com",
            "homepage": "https://github.com/dominosaurs"
        }
    ],
    "require": {
        "php": "^8.2",
        "calebporzio/sushi": "^2.5",
        "illuminate/console": "^11.0 || ^12.0 || ^13.0",
        "illuminate/database": "^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.9",
        "laravel/boost": "^2.4",
        "laravel/pint": "^1.25",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.4",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "TerloquentID\\": "src/"
        }
    },
    "scripts": {
        "lint": [
            "pint",
            "phpstan analyse -c phpstan.neon"
        ],
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ],
        "test": [
            "@clear",
            "@php vendor/bin/pest"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        },
        "preferred-install": "dist",
        "optimize-autoloader": true
    },
    "extra": {
        "dependencies-note": [
            "Requires data from https://github.com/dominosaurs/id-administrative-divisions"
        ],
        "laravel": {
            "providers": [
                "TerloquentID\\Providers\\TerloquentIDServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload-dev": {
        "psr-4": {
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/",
            "Tests\\": "tests/"
        }
    }
}
